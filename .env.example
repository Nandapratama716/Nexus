# ==========================================
# NEXUS - GLOBAL ENVIRONMENT VARIABLES
# ==========================================

# --- 1. Database (PostgreSQL) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=nexus_db
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=nexus

# --- 2. Cache & Message Broker (Redis) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- 3. Go Core Service (Backend) ---
CORE_SERVICE_PORT=8080
CORE_SERVICE_URL=http://localhost:8080
JWT_SECRET=super-secret-key-123

# --- 4. Python AI Service (FastAPI) ---
AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://localhost:8000
OLLAMA_MODEL=mistral

# --- 5. Next.js Dashboard (Frontend) ---
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# --- 6. 3rd Party Integrations ---
# Midtrans (Payment Gateway)
MIDTRANS_SERVER_KEY=SB-Mid-server-MOCK-KEY-12345
MIDTRANS_CLIENT_KEY=SB-Mid-client-MOCK-KEY-12345
MIDTRANS_IS_PRODUCTION=false

# --- 7. Tools ---
PGADMIN_EMAIL=admin@nexus.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
